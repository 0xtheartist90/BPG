# Neon Postgres (required) — get pooler URL from https://console.neon.tech
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Admin panel password (required)
ADMIN_PASSWORD=choose-a-strong-password

# Resend email API key (required for contact form)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Vercel Blob (required for image uploads in admin)
# Get from: Vercel Dashboard → Project → Storage → Create Blob Store → Token
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# Optional: Bundle analyzer
BUNDLE_ANALYZER_ENABLED=false
